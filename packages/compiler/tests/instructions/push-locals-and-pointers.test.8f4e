module pointerDereferenceDepthAssertions
; A pointer-to-pointer can be pushed as an address or dereferenced to the pointee value.
float value 1.5
float* ptr &value
float** pptr &ptr

push *pptr
push &value
call assert

push **pptr
push 1.5
call assertf
moduleEnd
entryEnd

