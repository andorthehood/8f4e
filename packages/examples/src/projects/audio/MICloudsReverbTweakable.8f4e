module pcmPlayer
; @pos -5 -27
; @home left
use env

int16[] buffer ASSET_PIANO_SIZE/2
; @config bin.piano.memory buffer
int16* playhead &buffer
float out

; @wave2 &buffer count(buffer) playhead

; Read sample at playhead
; write it to output
push &out
push *playhead
castToFloat
push max(buffer)
castToFloat
div
store

; Advance the playhead
push &playhead
push playhead
push sizeof(buffer)
add
store

; Reset playhead
; when reaches buffer end
push playhead
push buffer&
greaterThan
if
push &playhead
push &buffer
store
ifEnd

moduleEnd
