module modSamplePlayer1
; @pos 422 -7
; @tab 6 20
use env

int*	period	&period1:out
int*	trigger	&trigger1:out
int*	sampleNumber	&sampleNumber1:out
int8*	sampleAddress	; @w
int8*	playhead	; @w
int	sampleSize	; @w
; @wave2 sampleAddress sampleSize playhead
float out; @w
; @hide

float _position 
int _playing

push &sampleAddress
push *sampleNumber
call sampleNumberToAddr
store

push &sampleSize
push *sampleNumber
call sampleNumberToSize
store

push *trigger
risingEdge
if
push &_playing
push 1
store
push &_position
push 0
store
ifEnd

; Calculate read address
push &playhead
push _position
castToInt
push sampleAddress
add
store

; Read sample at playhead
; write it to output
push &out
push *playhead
castToFloat
push max(*sampleAddress) ; max value
castToFloat
div
store

; Advance the playhead
push _playing
if
push &_position
push _position
push *period
call period2Step
add
store
ifEnd

push *sampleNumber
call sampleNumberCanLoop

push _position
castToInt
push *sampleNumber
call sampleNumberToRepeatEnd
greaterThan
and
if
push &_position
push *sampleNumber
call sampleNumberToRepeatOffset
castToFloat
store
ifEnd

; Stop playing
; when reaches buffer end
push _position
castToInt
push *sampleNumber
call sampleNumberToSize
greaterThan
if
push &_playing
push 0
store
ifEnd

moduleEnd

