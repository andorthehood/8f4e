{
	"name": "@8f4e/stdlib",
	"sourceRoot": "std",
	"projectType": "library",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/manifest.json"],
			"options": {
				"command": "node scripts/generate-manifest.mjs",
				"cwd": "{projectRoot}"
			}
		},
		"generate-manifest": {
			"executor": "nx:run-commands",
			"cache": true,
			"inputs": ["default"],
			"outputs": ["{projectRoot}/manifest.json"],
			"options": {
				"command": "node scripts/generate-manifest.mjs",
				"cwd": "{projectRoot}"
			}
		}
	},
	"tags": ["type:library", "scope:core"]
}
