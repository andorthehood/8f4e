8f4e/v1

; Bitwise instruction behavior
; is checked through the shared
; imported assert helper.
entry test
module andAssertions
; `and` should return only the
; bits present in both operands.
push 1
push 0
and
call assert 0

push 3
push 6
and
call assert 2
moduleEnd

; `or` should return the bits
; present in either operand.
module orAssertions
push 1
push 0
or
call assert 1

push 3
push 6
or
call assert 7
moduleEnd

; `xor` should return only bits
; that differ between operands.
module xorAssertions
push 1
push 0
xor
call assert 1

push 3
push 6
xor
call assert 5
moduleEnd

; shiftLeft moves integer bits
; left by the requested amount.
module shiftLeftAssertions
push 1
push 1
shiftLeft
call assert 2

push 1
push 2
shiftLeft
call assert 4

push 3
push 3
shiftLeft
call assert 24
moduleEnd

; shiftRight moves integer bits
; right by the requested amount.
module shiftRightAssertions
push 1
push 1
shiftRight
call assert 0

push 8
push 2
shiftRight
call assert 2

push 12
push 3
shiftRight
call assert 1
moduleEnd
entryEnd
