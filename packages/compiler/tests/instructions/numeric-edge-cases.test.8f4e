8f4e/v1

; Numeric edge cases are
; executable fixtures so the
; real Wasm
; runtime path is covered.
entry test
module castToIntSaturatesOutOfRangeFloat32
; castToInt should saturate
; positive out-of-range float32
; values.
push 2147483648.0
castToInt
call assert 2147483647
moduleEnd

module castToIntConvertsNaNToZero
; castToInt should convert NaN
; float32 values to zero.
push -1.0
sqrt
castToInt
call assert 0
moduleEnd

module minMaxIntAssertions
; min and max should select the
; smaller and larger signed
; integer operands.
push 10
push -3
min
call assert -3

push 10
push -3
max
call assert 10
moduleEnd

module minMaxFloatAssertions
; min and max should select the
; smaller and larger float32
; operands.
push 0.5
push 0.7
min
call assert 0.5

push 0.5
push 0.7
max
call assert 0.7
moduleEnd

module minMaxFloat64Assertions
; min and max should select the
; smaller and larger float64
; operands.
push 1.25f64
push 1.125f64
min
call assert 1.125f64

push 1.25f64
push 1.125f64
max
call assert 1.25f64
moduleEnd

module remainderWithNonZeroConstant
; Remainder should run when the
; divisor is a known non-zero
; constant.
push 5
push 2
remainder
call assert 1
moduleEnd
entryEnd
