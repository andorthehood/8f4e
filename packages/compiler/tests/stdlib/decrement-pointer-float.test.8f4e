entry test
module decrementPointerFloatAssertions
; it decrements and wraps a
; mutable float pointer within a
; circular buffer.
float[] buffer 3 1.0
float* pointer &buffer

push &pointer
push &buffer
push count(buffer)
call decrementPointer

push pointer
push buffer&
call assert

push &pointer
push &buffer
push count(buffer)
call decrementPointer

push pointer
push &buffer+sizeof(buffer)
call assert

push &pointer
push &buffer
push count(buffer)
call decrementPointer

push pointer
push &buffer
call assert
moduleEnd
entryEnd
