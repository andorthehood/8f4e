includes
include std/math/trig/cosine
includesEnd

entry test
module cosineAssertions
; it approximates cosine at
; cardinal phase points.
push 0.0
call cosine
call assert 1.0

push 1.570796326794896
call cosine
call assert 0.0

push 3.141592653589793
call cosine
call assert -1.0

push -1.570796326794896
call cosine
call assert 0.0
moduleEnd
entryEnd
