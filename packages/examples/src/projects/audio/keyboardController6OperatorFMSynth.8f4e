defineMacro adsrEnv
; @pos -75 74
; @hide
; @tab 8

const	ATTACK 1
const	DECAY 2
const	SUSTAIN 3
const	RELEASE 4

int	_state RELEASE
int	_counter

; Start ATTACK
push	*trigger
risingEdge
if
push	&_state
push	ATTACK
store
push	&_counter
push	attackTime
store
ifEnd

; ATTACK math
push	_state
push	ATTACK
equal
push	_counter
push	0
greaterThan
and
if
push	&out
push	1.0
push	_counter
castToFloat
push	attackTime
castToFloat
ensureNonZero
div
sub
store
ifEnd

; Transition from ATTACK to
; DECAY
push	_counter
equalToZero
push	_state
push	ATTACK
equal
and
if ; End of attack
push	&_state
push	DECAY
store
push	&_counter
push	decayTime
store
ifEnd

; DECAY math
push	_state
push	DECAY
equal
push	_counter
push 0
greaterThan
and
if
push	&out
push	sustainLevel
push	_counter
castToFloat
push   decayTime
castToFloat
ensureNonZero
div
push	1.0
push	sustainLevel
sub
mul
add
store
ifEnd

; Transition from DECAY
; to SUSTAIN if enabled,
; otherwise to RELEASE
push	_state
push	DECAY
equal
push	_counter
equalToZero
and
if
push	&_state
push	sustainEnabled
if
push	SUSTAIN
else
push	&_counter
push	releaseTime
store
push	RELEASE
ifEnd int
store
ifEnd

; SUSTAIN math
push	_state
push	SUSTAIN
equal
push    *trigger
push    0
greaterThan
and
if
push &out
push sustainLevel
store
ifEnd

; Transition from SUSTAIN to
; RELEASE
push	_state
push	SUSTAIN
equal
push	*trigger
equalToZero
and
if
push	&_state
push	RELEASE
store
push	&_counter
push	releaseTime
store
ifEnd

; RELEASE math
push	_state
push	RELEASE
equal
push	_counter
push	0
greaterThan
and
if
push	&out
push	_counter
castToFloat
push	releaseTime
castToFloat
ensureNonZero
div
push	sustainLevel
mul
store
ifEnd

; Decrement and wrap counter 
push	_counter
push	0
greaterThan
if
push	&_counter
push	_counter
push	1
sub
store
ifEnd

defineMacroEnd

