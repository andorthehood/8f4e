push 2
mul
push 4
call assert

push 2
push 0
mul
push 0
call assert
moduleEnd

; Division works with a non-zero guard on the divisor.
module divAssertions
push 100
push 10
ensureNonZero
div
push 10
call assert
moduleEnd

; remainder works when the divisor is guarded as non-zero.
