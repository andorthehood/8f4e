module blepLowpass
; @pos 274 -73
float* in &blepSmoother:out
float state 0.0 ; @w
float out ; @w

use math
use env

const MINUS_2_PI -2*PI
const CUTOFF_TERM MINUS_2_PI*4400
const EXPONENT CUTOFF_TERM/SAMPLE_RATE
const DECAY E^EXPONENT
const COEFFICIENT 1-DECAY

push &out
push state
push *in
push state
sub
push COEFFICIENT
mul
add
store

push &state
push out
store

moduleEnd

module blepSmoother
; @pos 216 -73
float* raw &pcmPlayer:out
float* readPosition &pcmPlayer:readPosition
float* increment &params:increment
float* delta &sampleDelta:out
int index 0 ; @w
float out ; @w
float[] blepBuffer 16

; Inject the 16-tap BLEP kernel
; only when the sample output changed.
push *delta
notZero
if
loop 16
push &blepBuffer
push index
loopIndex
call wrapAdd16
push &minBLEPLUT:0
push *readPosition
push *increment
call positionIncrementToBlepPhaseInterpolated
loopIndex
push *delta
call blepValueAtInterpolated
call addBlepAt
loopEnd
ifEnd

; Read the correction sample
; at the current ring position.
; Mix the raw sample with the
; current BLEP correction.
push &out
push *raw
push &blepBuffer
push index
call blepQueuePtr
loadFloat
add
store

; Clear the consumed correction
; at the current ring position.
push &blepBuffer
push index
call blepQueuePtr
push 0.0
store

; Advance the ring position
; for the next output sample.
push &index
push index
push 1
call wrapAdd16
store

moduleEnd

