{
	"name": "@8f4e/memory-reference-resolver",
	"sourceRoot": "packages/compiler/packages/memory-reference-resolver/src",
	"projectType": "library",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist"],
			"options": {
				"command": "rm -rf dist && tsc --emitDeclarationOnly && vite build",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "biome check --write packages/compiler/packages/memory-reference-resolver/src packages/compiler/packages/memory-reference-resolver/tests",
				"cwd": "{workspaceRoot}"
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "rm -rf dist && concurrently -k -n types,bundle \"tsc --emitDeclarationOnly --watch\" \"vite build --watch\"",
				"cwd": "{projectRoot}"
			}
		},
		"test": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/@8f4e/memory-reference-resolver"],
			"dependsOn": ["^build"],
			"options": {
				"config": "{projectRoot}/vitest.config.ts",
				"reportsDirectory": "{workspaceRoot}/coverage/@8f4e/memory-reference-resolver"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --noEmit",
				"cwd": "{projectRoot}"
			}
		}
	},
	"tags": ["type:library", "scope:core"]
}
