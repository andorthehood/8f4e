module sequencer
; @pos -34 -24

int* start &risen:
int* end risen:&
int* pointer &risen:
int* tick &tick:out
int note
int noteStart
int noteEnd
int noteOn

; @debug note
; @debug noteStart
; @debug noteEnd
; @debug noteOn

push pointer
hasChanged
if
; Load note
push &note
push *pointer
push 0xff000000
and
push 24
shiftRight
store

; Load note start delta t
push &noteStart
push *pointer
push 0x00ff0000
and
push 16
shiftRight
store

; Load note end delta t
push &noteEnd
push *pointer
push 0x0000ff00
and 
push 8
shiftRight
store
ifEnd

; Decrement the counters
push *tick
risingEdge
if
push &noteStart
push noteStart
push 1
sub
store
push &noteEnd
push noteEnd
push 1
sub
store
ifEnd

; Set noteOn based on
; noteStart
push &noteOn
push noteStart
push -1
lessOrEqual
store

; Increment the pointer
; if the note ended
push noteEnd
push -1
lessOrEqual
if
push &pointer
push pointer
push 4
add
store
ifEnd

; Wrap the pointer
push pointer
push end
greaterThan
if
push &pointer
push start
store
ifEnd

moduleEnd

