function sine
; @pos 3 -8
; Polynomial approximation 
; of the sine function with
; Taylor series (7th order)
; Only works in the range of
; [-PI, PI]
param float x

use math

; Fold to [-pi/2, pi/2]
push x
push HALF_PI
greaterThan
if
push PI
push x
sub
localSet x
ifEnd

push x
push HALF_PI
push -1.0
mul
lessThan
if
push PI
push -1.0
mul
push x
sub
localSet x
ifEnd

local float x2
push x
dup
mul
localSet x2

; Taylor coefficients
const T1 -0.1666666666
const T2 0.0083333333
const T3 -0.000198412

push x2
push T3
mul
push T2
add
push x2
mul
push T1
add
push x2
mul
push 1.0
add
push x
mul

functionEnd float

module adsrEnv
; @pos 43 -13
; @tab 8
use env

int*	trigger &sequencer:noteOn
int	attackTime SAMPLE_RATE/1000
float	attacLevel 1.0
int	decayTime SAMPLE_RATE/1000
float	sustainLevel 0.8
int	releaseTime SAMPLE_RATE/200
float	out

const	ATTACK 1
const	DECAY 2
const	SUSTAIN 3
const	RELEASE 4

int	_state RELEASE
int	_counter

; Start ATTACK
push	*trigger
risingEdge
if
push	&_state
push	ATTACK
store
push	&_counter
push	attackTime
store
ifEnd

; ATTACK math
push	_state
push	ATTACK
equal
push	_counter
push	0
greaterThan
and
if
push	&out
push	1.0
push	_counter
castToFloat
push	attackTime
castToFloat
ensureNonZero
div
sub
store
ifEnd

; Transition from ATTACK to
; DECAY
push	_counter
equalToZero
push	_state
push	ATTACK
equal
and
if ; End of attack
push	&_state
push	DECAY
store
push	&_counter
push	decayTime
store
ifEnd

; DECAY math
push	_state
push	DECAY
equal
push	_counter
push    0
greaterThan
and
if
push	&out
push	sustainLevel
push	_counter
castToFloat
push   decayTime
castToFloat
ensureNonZero
div
push	1.0
push	sustainLevel
sub
mul
add
store
ifEnd

; Transition from DECAY
; to SUSTAIN
push	_state
push	DECAY
equal
push	_counter
equalToZero
and
if
push	&_state
push	SUSTAIN
store
ifEnd

; SUSTAIN math
push	_state
push	SUSTAIN
equal
push    *trigger
push    0
greaterThan
and
if
push    &out
push    sustainLevel
store
ifEnd

; Transition from SUSTAIN to
; RELEASE
push	_state
push	SUSTAIN
equal
push	*trigger
equalToZero
and
if
push	&_state
push	RELEASE
store
push	&_counter
push	releaseTime
store
ifEnd

; RELEASE math
push	_state
push	RELEASE
equal
push	_counter
push	0
greaterThan
and
if
push	&out
push	_counter
castToFloat
push	releaseTime
castToFloat
ensureNonZero
div
push	sustainLevel
mul
store
ifEnd

; Decrement and wrap counter 
push	_counter
push	0
greaterThan
if
push	&_counter
push	_counter
push	1
sub
store
ifEnd

moduleEnd

module audioout
; @pos 210 -22
; @home
use env

float* in &reverb:out

; Audio buffer
float[] buffer AUDIO_BUFFER_SIZE
; ~audioOutput buffer 0 0
; ~audioOutput buffer 0 1
int pointer &buffer

; @plot &buffer count(buffer)

; Store the input value
; in the buffer
push pointer
push *in
store

; Increment the buffer 
; pointer by the
; buffer word size
push &pointer
push pointer
push sizeof(buffer)
add
store

; Reset the buffer pointer
; when it reaches the end
; of the buffer
push pointer
push buffer&
greaterThan
if
push &pointer
push &buffer
store
ifEnd

moduleEnd

module carrier
; @pos 133 -22
use env

float* frequency &midiToFreq:out
float* phaseMod &modulator:out
float phase 0.0
float out
float ratio 2.0
float* ampMod &adsrEnv:out 

; @slider modIndex 0 10.0

use math

; Advance phase by
; TAU * frequency / SAMPLE_RATE
push &phase
push phase
push TAU
push *frequency
mul
push ratio
mul
push SAMPLE_RATE
castToFloat
ensureNonZero
div
add
store 

; Wrap phase when it exceeds PI
push phase
push PI
greaterThan
if
push &phase
push NEG_PI
store
ifEnd

push &out
push phase
push *phaseMod
add
; You can swap this call 
; with any periodic function
call sine
push *ampMod
mul
store

moduleEnd

