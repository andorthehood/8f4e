constants mod
; @pos 195 -153
; @tab 30
use env
; Row layout (little-endian)
const SAMPLE_HI_NIBBLE	0x000000F0
const PERIOD_HI	0x0000000F
const PERIOD_LO	0x0000FF00
const PERIOD_SHIFT	8
const SAMPLE_LO_NIBBLE	0x00F00000
const SAMPLE_LO_NIBBLE_SHIFT	20
const EFFECT_NIBBLE	0x000F0000
const EFFECT_NIBBLE_SHIFT	16
const EFFECT_PARAM	0xFF000000
const EFFECT_PARAM_SHIFT	24
; AMIGA magic const
const PAL_AMIGA_CLOCK	7093789.2
; Default ticks per row
const SPEED	6
; PAL VBlank: ticks/sec = BPM * 2/5
const TICKS_X5	SPEED*5
const TICKS_HALF	TICKS_X5/2
; Samples per row = ROW_SAMPLES / tempo
const ROW_SAMPLES	SAMPLE_RATE*TICKS_HALF
; Effects
const ARPEGGIO	0x0
const PITCH_SLIDE_UP	0x1
const PITCH_SLIDE_DOWN	0x2
const TONE_PORTAMENTO	0x3
const VIBRATE	0x4
const TONE_PORTA_VOL_SLIDE	0x5
const VIBRATO_VOL_SLIDE	0x6
const TREMOLO	0x7
const SAMPLE_OFFSET	0x9
const VOLUME_SLIDE	0xA
const PATTERN_JUMP	0xB
const SET_VOLUME	0xC
const PATTERN_BREAK	0xD
const EXTENDED_EFFECTS	0xE
const SET_SPEED	0xF
; Extended effects
const SET_FILTER	0xE0
const FINE_SLIDE_UP	0xE1
const FINE_SLIDE_DOWN	0xE2
const GLISSANDO_CONTROL	0xE3
const SET_VIBRATO_WAVEFORM	0xE4
const SET_FINETUNE	0xE5
const PATTERN_LOOP	0xE6
const SET_TREMOLO_WAVEFORM	0xE7
const RETRIGGER_NOTE	0xE9
const FINE_VOLUME_SLIDE_UP	0xEA
const FINE_VOLUME_SLIDE_DOWN	0xEB
const NOTE_CUT	0xEC
const NOTE_DELAY	0xED
const PATTERN_DELAY	0xEE
const INVERT_LOOP	0xEF

constantsEnd

