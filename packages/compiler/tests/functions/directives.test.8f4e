; Directive prologues are accepted directly after block declarations.
entry test
module skippedDirectiveModule
#skipExecution
#loopCap 4
int value 123

push &value
push 999
store
moduleEnd

module directiveAssertions
int output 0

push &skippedDirectiveModule:value
load
push 123
call assert

push &output
push 9
call writeWithDirectivePrologue

push output
push 9
call assert
moduleEnd
entryEnd

function writeWithDirectivePrologue
#export writeWithDirectivePrologue
#impure
#loopCap 4
param int address
param int value
push address
push value
store
functionEnd
