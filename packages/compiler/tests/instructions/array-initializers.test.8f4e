8f4e/v1

; Array initializer values
; should be visible after
; initDefaults
; runs.
entry test
module intArrayInitializerAssertions
; int[] trailing values
; initialize elements from index
; 0 and
; leave omitted elements zeroed.
int[] notes 10 48 50 53

push &notes
load
call assert 48

push &notes
push 1
push sizeof(notes)
mul
add
load
call assert 50

push &notes
push 2
push sizeof(notes)
mul
add
load
call assert 53

push &notes
push 3
push sizeof(notes)
mul
add
load
call assert 0
moduleEnd

module expressionInitializerAssertions
; Constants and compile-time
; expressions can provide
; initializer
; values.
const ROOT 48
int[] notes 4 ROOT ROOT+2 ROOT+5

push &notes
load
call assert 48

push &notes
push 1
push sizeof(notes)
mul
add
load
call assert 50

push &notes
push 2
push sizeof(notes)
mul
add
load
call assert 53
moduleEnd

module hexadecimalInitializerAssertions
; Hexadecimal initializer values
; should resolve as ordinary
; integers.
int[] foo 2 0x01 0x02

push &foo
load
call assert 1

push &foo
push 1
push sizeof(foo)
mul
add
load
call assert 2
moduleEnd

module narrowInitializerAssertions
; Narrow integer arrays should
; store initializer values at
; their
; element byte width.
int8[] bytes 4 1 2 3 4
int16[] shorts 3 1000 2000 3000

push &bytes
load8u
call assert 1

push &bytes
push 1
push sizeof(bytes)
mul
add
load8u
call assert 2

push &bytes
push 2
push sizeof(bytes)
mul
add
load8u
call assert 3

push &bytes
push 3
push sizeof(bytes)
mul
add
load8u
call assert 4

push &shorts
load16s
call assert 1000

push &shorts
push 1
push sizeof(shorts)
mul
add
load16s
call assert 2000

push &shorts
push 2
push sizeof(shorts)
mul
add
load16s
call assert 3000
moduleEnd

module sparseInitializerAssertions
; Large sparse arrays should
; initialize specified values
; and
; leave omitted values zeroed.
int[] huge 1000000 1

push &huge
load
call assert 1

push &huge
push 1
push sizeof(huge)
mul
add
load
call assert 0

push &huge
push 999999
push sizeof(huge)
mul
add
load
call assert 0
moduleEnd
entryEnd
