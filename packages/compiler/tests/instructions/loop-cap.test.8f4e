8f4e/v1

; Loop cap behavior is checked from source-level fixtures.
entry test
module defaultLoopCapAssertions
; Plain loops stop at the compiler default cap.
int counter
loop
push &counter
push counter
push 1
add
store
loopEnd

push counter
call assert 1000
moduleEnd

module directiveLoopCapAssertions
; #loopCap changes the cap for subsequent loops in the module.
#loopCap 500
int counter
loop
push &counter
push counter
push 1
add
store
loopEnd

push counter
call assert 500
moduleEnd

module explicitLoopCapAssertions
; An explicit loop cap overrides the default cap.
int counter
loop 32
push &counter
push counter
push 1
add
store
loopEnd

push counter
call assert 32
moduleEnd

module constantLoopCapAssertions
; Constant and constant-expression caps resolve at compile time.
const LOOP_COUNT 32
int counter
loop LOOP_COUNT
push &counter
push counter
push 1
add
store
loopEnd

push counter
call assert 32

const FRAMES 16
int expressionCounter
loop FRAMES*2
push &expressionCounter
push expressionCounter
push 1
add
store
loopEnd

push expressionCounter
call assert 32
moduleEnd

module explicitCapOverridesDirectiveAssertions
; Explicit loop arguments override #loopCap.
#loopCap 500
int counter
loop 12
push &counter
push counter
push 1
add
store
loopEnd

push counter
call assert 12
moduleEnd

module nestedLoopCapAssertions
; Nested loops resolve their own caps independently.
int outerCounter
int innerCounter
loop 5
push &outerCounter
push outerCounter
push 1
add
store

loop 3
push &innerCounter
push innerCounter
push 1
add
store
loopEnd
loopEnd

push outerCounter
call assert 5

push innerCounter
call assert 15
moduleEnd

module zeroLoopCapAssertions
; A zero cap exits immediately on the first guard check.
int counter
loop 0
push &counter
push counter
push 1
add
store
loopEnd

push counter
call assert 0
moduleEnd

module functionLoopCapAssertions
; Function-scoped #loopCap should bound loops inside functions.
call countWithFunctionLoopCap
call assert 7
moduleEnd
entryEnd

function countWithFunctionLoopCap
#loopCap 7
local int counter

loop
push counter
push 1
add
localSet counter
loopEnd

push counter
functionEnd int
