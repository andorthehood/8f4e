module modulator
; @pos 92 -22
use env
use math

float* frequency &midiToFreq:out
float phase 0.0
float out
float ratio 4.0
float* ampMod &adsrEnv:out

; Advance phase by
; TAU * frequency / SAMPLE_RATE
push &phase
push phase
push TAU
push *frequency
mul
push ratio
mul
push SAMPLE_RATE
castToFloat
ensureNonZero
div
add
store 

; Wrap phase when it exceeds PI
push phase
push PI
greaterThan
if
push &phase
push NEG_PI
store
ifEnd

push &out
push phase
; You can swap this call 
; with any periodic function
call sine
push *ampMod
mul
store

moduleEnd

