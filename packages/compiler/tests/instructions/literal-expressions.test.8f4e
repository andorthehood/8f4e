8f4e/v1

; Literal and constant
; expressions are executed as
; regular
; language tests.
entry test
module validConstantNameAssertions
; Constants with valid names are
; available as int, float, and
; declaration defaults.
const TEST1 420
const TEST2 420.69
const TEST3 69

push TEST1
call assert 420

push TEST2
call assert 420.69

int output3 TEST3
push output3
call assert 69
moduleEnd

module fractionLiteralAssertions
; Fraction literals work in
; push, memory declarations, and
; constants.
push 1/16
call assert 0.0625

int intFraction 1/16
push intFraction
call assert 0

float floatFraction 1/16
push floatFraction
call assert 0.0625

int intWholeFraction 8/2
push intWholeFraction
call assert 4

float negativeFraction -1/2
push negativeFraction
call assert -0.5

const MY_FRACTION 1/8
push MY_FRACTION
call assert 0.125
moduleEnd

module literalMulDivExpressionAssertions
; Literal-only multiplication
; and division fold in const,
; push,
; and memory contexts.
const MUL_RESULT 16*2
push MUL_RESULT
call assert 32

const DIV_RESULT 8/2
push DIV_RESULT
call assert 4

push 16*2
call assert 32

push 1/2
call assert 0.5

push 0x10*2
call assert 32

push 0x10/2
call assert 8

push 3.5*4
call assert 14.0

int multipliedDefault 4*3
push multipliedDefault
call assert 12

int[] literalSizedBuffer 4*2
push count(literalSizedBuffer)
call assert 8
moduleEnd

module constantExpressionAssertions
; Constants can reference
; constants and shape memory
; sizes.
const SIZE 8
int[] dividedBuffer SIZE/2
push count(dividedBuffer)
call assert 4

int[] multipliedBuffer SIZE*2
push count(multipliedBuffer)
call assert 16

const HALF SIZE/2
push HALF
call assert 4

const SIGNED -1/SIZE
push SIGNED
call assert -0.125

push SIZE/2
call assert 4

int defaultFromExpression SIZE/2
push defaultFromExpression
call assert 4
moduleEnd

module sizeAndCountExpressionAssertions
; sizeof and count expressions
; work in constants, push, and
; buffer sizing.
int16[] samples 4
const BYTE_SIZE 123*sizeof(samples)
push BYTE_SIZE
call assert 246

const SAMPLE_BYTES sizeof(samples)*2
push SAMPLE_BYTES
call assert 4

const SIZE 8
const TOTAL SIZE*sizeof(samples)
push TOTAL
call assert 16

push sizeof(samples)*4
call assert 8

push SIZE*sizeof(samples)
call assert 16

push 123*sizeof(samples)
call assert 246

push 2*SIZE
call assert 16

float[] floatSamples 8
float* ptr &floatSamples
push count(*ptr)
call assert 8

int8[] smallSamples 4
int8* smallPtr &smallSamples
push min(*smallPtr)
call assert -128

int[] sizeofBuffer sizeof(samples)*2
push count(sizeofBuffer)
call assert 4

int[] source 8
int[] dest count(source)*2
push count(dest)
call assert 16
moduleEnd

module exponentExpressionAssertions
; Exponent expressions are
; supported for constants, push
; values,
; and buffer sizes.
const WIDTH 2^16
push WIDTH
call assert 65536

const SIZE 4
const TOTAL SIZE^3
push TOTAL
call assert 64

const EXP 8
const RESULT 2^EXP
push RESULT
call assert 256

push 2^SIZE
call assert 16

const MEMORY_EXP 3
int defaultFromExponent MEMORY_EXP^2
push defaultFromExponent
call assert 9

const BUFFER_BASE 2
int[] exponentialBuffer BUFFER_BASE^3
push count(exponentialBuffer)
call assert 8

int32[] samples 4
const SIZEOF_POWER sizeof(samples)^2
push SIZEOF_POWER
call assert 16
moduleEnd
entryEnd
