8f4e/v1

; Comparison instructions return
; integer booleans and are
; checked with assert.
entry test
module equalAssertions
; equal returns true for
; matching integer operands and
; false
; otherwise.
push 420
push 420
equal
call assert 1

push 420
push -420
equal
call assert 0

push 69
push 96
equal
call assert 0

push 0
push 0
equal
call assert 1
moduleEnd

module equalToZeroAssertions
; equalToZero returns true only
; for zero.
push 420
equalToZero
call assert 0

push -69
equalToZero
call assert 0

push 0
equalToZero
call assert 1
moduleEnd

module greaterThanIntAssertions
; greaterThan compares signed
; integers.
push 420
push 420
greaterThan
call assert 0

push 420
push 0
greaterThan
call assert 1

push 0
push 0
greaterThan
call assert 0

push 0
push 69
greaterThan
call assert 0

push 0
push -69
greaterThan
call assert 1
moduleEnd

module greaterThanFloatAssertions
; greaterThan compares floats
; and still returns an integer
; boolean.
push 420.1
push 420.1
greaterThan
call assert 0

push 420.1
push 0.001
greaterThan
call assert 1

push 0.001
push 0.001
greaterThan
call assert 0

push 0.001
push 69.1
greaterThan
call assert 0

push 0.001
push -69.1
greaterThan
call assert 1
moduleEnd

module greaterOrEqualIntAssertions
; greaterOrEqual returns true
; for equal or greater signed
; integers.
push 420
push 420
greaterOrEqual
call assert 1

push 420
push 0
greaterOrEqual
call assert 1

push 0
push 0
greaterOrEqual
call assert 1

push 0
push 69
greaterOrEqual
call assert 0

push 0
push -69
greaterOrEqual
call assert 1
moduleEnd

module greaterOrEqualFloatAssertions
; greaterOrEqual returns true
; for equal or greater floats.
push 420.1
push 420.1
greaterOrEqual
call assert 1

push 420.1
push 0.001
greaterOrEqual
call assert 1

push 0.001
push 0.001
greaterOrEqual
call assert 1

push 0.001
push 69.1
greaterOrEqual
call assert 0

push 0.001
push -69.1
greaterOrEqual
call assert 1
moduleEnd
entryEnd
