8f4e/v1

; Push should resolve locals,
; parameters, module memory, and
; pointer dereference depth
; correctly.
entry test
module pushLocalAssertions
; Function locals should
; round-trip through localSet
; and push.
call readIntLocal
call assert 7

call readFloatLocal
call assertf 1.5

push 2.0f64
call doubleFloat64
call assertf64 4.0f64
moduleEnd

module localShadowMemoryAssertions
; Function parameters should
; shadow same-named module
; memory
; identifiers.
int value 42
push 7
call shadowValue
call assert 7
moduleEnd

module pointerDereferenceDepthAssertions
; A pointer-to-pointer can be
; pushed as an address or
; dereferenced to the pointee
; value.
float value 1.5
float* ptr &value
float** pptr &ptr

push *pptr
push &value
asPointer float*
call assert

push **pptr
call assertf 1.5
moduleEnd
entryEnd

function readIntLocal
local int temp
push 7
localSet temp
push temp
functionEnd int

function readFloatLocal
local float temp
push 1.5
localSet temp
push temp
functionEnd float

function doubleFloat64
param float64 value
push value
push 2.0f64
mul
functionEnd float64

function shadowValue
param int value
push value
functionEnd int
