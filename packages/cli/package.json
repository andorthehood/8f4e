  },
  "homepage": "https://github.com/andorthehood/8f4e#readme",
  "dependencies": {
    "@8f4e/compiler": "*",
    "@8f4e/compiler-types": "*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "vitest": "4.0.13"
  }
}
