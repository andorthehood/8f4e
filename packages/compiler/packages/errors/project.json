{
	"name": "@8f4e/compiler-errors",
	"sourceRoot": "src",
	"projectType": "library",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist"],
			"dependsOn": ["^build"],
			"options": {
				"command": "rm -rf dist tsconfig.tsbuildinfo && vite build && tsc --emitDeclarationOnly",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "eslint src --fix",
				"cwd": "{projectRoot}"
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "rm -rf dist && concurrently -k -n types,bundle \"tsc --emitDeclarationOnly --watch\" \"vite build --watch\"",
				"cwd": "{projectRoot}"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"dependsOn": ["^build"],
			"options": {
				"command": "tsc --noEmit",
				"cwd": "{projectRoot}"
			}
		}
	},
	"tags": ["type:library", "scope:core"]
}
