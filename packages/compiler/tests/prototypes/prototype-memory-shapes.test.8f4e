8f4e/v1

; describes a reusable module memory shape with defaults
prototype oscillatorState
float phase
float frequency 440
prototypeEnd

entry test
module oscA
shape oscillatorState
int localA 11

; it expands prototype fields before local declarations
push phase
push 0.0
call assertf

; it preserves default values from prototype fields
push frequency
push 440.0
call assertf

; it preserves declarations written in the consuming module
push localA
push 11
call assert

; it lays out expanded prototype fields in declaration order
push &phase
push &frequency
lessThan
push 1
call assert

; it lays out local declarations after a leading shape instruction
push &frequency
push &localA
lessThan
push 1
call assert
moduleEnd

module oscB
int localB 22
shape oscillatorState

; it preserves declarations that appear before a shape instruction
push localB
push 22
call assert

; it expands prototype fields after earlier local declarations
push phase
push 0.0
call assertf

; it reuses prototype defaults in each consuming module
push frequency
push 440.0
call assertf

; it lays out shape fields after preceding local declarations
push &localB
push &phase
lessThan
push 1
call assert

; it allocates separate storage for each module that uses the shape
push &phase
push &oscA:phase
notEqual
push 1
call assert
moduleEnd
entryEnd
