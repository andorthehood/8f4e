float* diffusion 
- &controlValues:smear1Diffusion

; @wave2 &buffer count(buffer) pointer

local float writeValue 

push *in
push *pointer
push *diffusion
mul
add
localSet writeValue

push &out
push *pointer
push writeValue
push *diffusion
mul
sub
store

; Store the allpass
; write value
push pointer
push writeValue
store 

; Advance and wrap
; circular buffer pointer
push &pointer
push &buffer
push count(buffer)
call advancePointer

moduleEnd
