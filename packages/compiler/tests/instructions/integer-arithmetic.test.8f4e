8f4e/v1

; Integer arithmetic behavior is
; checked through the shared
; imported assert helper.
entry test
module addAssertions
; Addition keeps signed integer
; behavior across positive,
; negative, and zero operands.
push 2
push 2
add
call assert 4

push -1
push 1
add
call assert 0

push -69
push 0
add
call assert -69

push 420
push 0
add
call assert 420
moduleEnd

; Subtraction keeps signed
; integer behavior across
; positive,
; negative, and zero operands.
module subAssertions
push 2
push 2
sub
call assert 0

push -1
push 1
sub
call assert -2

push -69
push 0
sub
call assert -69

push 420
push 0
sub
call assert 420
moduleEnd

; Multiplication handles
; ordinary products and zero
; operands.
module mulAssertions
push 2
push 2
mul
call assert 4

push 2
push 0
mul
call assert 0
moduleEnd

; Division works with a non-zero
; guard on the divisor.
module divAssertions
push 100
push 10
ensureNonZero
div
call assert 10
moduleEnd

; remainder works when the
; divisor is guarded as
; non-zero.
module remainderAssertions
push 4
push 2
ensureNonZero
remainder
call assert 0

push 3
push 2
ensureNonZero
remainder
call assert 1
moduleEnd

; abs returns positive integer
; magnitudes.
module absAssertions
push 1
abs
call assert 1

push -1
abs
call assert 1

push -69
abs
call assert 69

push 420
abs
call assert 420

push 8
push -2
abs
div
call assert 4
moduleEnd
entryEnd
