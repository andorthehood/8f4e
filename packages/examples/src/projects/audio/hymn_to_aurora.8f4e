module audiooutL
; @pos 533 -4
use env

float* in &mixer:outL
float[] buffer AUDIO_BUFFER_SIZE
; ~audioOutput buffer 0 0
int pointer &buffer

; @plot buffer -1 1
; Store the input value
; in the buffer
push pointer
push *in
store

; Increment the buffer 
; pointer with the word size
push &pointer
push pointer
push sizeof(buffer)
add
store

; Reset the buffer pointer
; when it reaches the end
; of the buffer
push pointer
push buffer&
greaterThan 
if
push &pointer
push &buffer
store
ifEnd

moduleEnd

