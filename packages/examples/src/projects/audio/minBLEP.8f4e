module sampleDelta
; @pos 177 -73
float* in &pcmPlayer:out
float previous 0.0
float out

push &out
push previous
push *in
sub
store

push &previous
push *in
store

moduleEnd

module scopeOriginal
; @pos 44 -73

float* in &pcmPlayer:out
float[] buffer 128
float* pointer &buffer

; Before BLEP    ;;;;;
;              ..;;;;;..
; You can see   `:;;;:'
; how chunky the  `:'
; signal is.
        
; @plot &buffer count(buffer)

push pointer
push *in
store

push &pointer
push pointer
push sizeof(buffer)
add
store

push pointer
push buffer&
greaterThan
if
push &pointer
push &buffer
store
ifEnd

moduleEnd

