8f4e/v1

; Intermodule min(...) and
; max(...) references should
; resolve
; element bounds.
entry test
module intBoundsSource
int[] ints 10 0
int32[] int32s 5 0
int16[] signed16 10 0
int16u[] unsigned16 10 0
int8[] signed8 10 0
int8u[] unsigned8 10 0
moduleEnd

module floatBoundsSource
float[] floats 7 0.0
moduleEnd

module integerBoundAssertions
; Integer min/max references
; should reflect the source
; element
; type.
int minInt min(intBoundsSource:ints)
int maxInt max(intBoundsSource:ints)
int minInt32 min(intBoundsSource:int32s)
int maxInt32 max(intBoundsSource:int32s)
int minSigned16 min(intBoundsSource:signed16)
int maxSigned16 max(intBoundsSource:signed16)
int minUnsigned16 min(intBoundsSource:unsigned16)
int maxUnsigned16 max(intBoundsSource:unsigned16)
int minSigned8 min(intBoundsSource:signed8)
int maxSigned8 max(intBoundsSource:signed8)
int minUnsigned8 min(intBoundsSource:unsigned8)
int maxUnsigned8 max(intBoundsSource:unsigned8)

push minInt
call assert -2147483648

push maxInt
call assert 2147483647

push minInt32
call assert -2147483648

push maxInt32
call assert 2147483647

push minSigned16
call assert -32768

push maxSigned16
call assert 32767

push minUnsigned16
call assert 0

push maxUnsigned16
call assert 65535

push minSigned8
call assert -128

push maxSigned8
call assert 127

push minUnsigned8
call assert 0

push maxUnsigned8
call assert 255
moduleEnd

module floatBoundAssertions
; Float min/max references
; should use the finite float32
; bounds.
float minFloat min(floatBoundsSource:floats)
float maxFloat max(floatBoundsSource:floats)

push minFloat
call assertf -3.4028234663852886e38

push maxFloat
call assertf 3.4028234663852886e38
moduleEnd

module outOfOrderBoundsAssertions
; Bounds references can resolve
; to modules declared later.
int minValue min(lateBoundsSource:buffer)
int maxValue max(lateBoundsSource:buffer)

push minValue
call assert -2147483648

push maxValue
call assert 2147483647
moduleEnd

module lateBoundsSource
int[] buffer 8 0
moduleEnd

module combinedBoundsAssertions
; Bounds, count, and address
; references can be used
; together in
; one module.
int* ptr &combinedBoundsSource:buffer
int size count(combinedBoundsSource:buffer)
int minValue min(combinedBoundsSource:buffer)
int maxValue max(combinedBoundsSource:buffer)

push *ptr
call assert 12

push size
call assert 12

push minValue
call assert -2147483648

push maxValue
call assert 2147483647
moduleEnd

module combinedBoundsSource
int[] buffer 12 12
moduleEnd
entryEnd
