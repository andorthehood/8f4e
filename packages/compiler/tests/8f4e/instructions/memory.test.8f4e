8f4e/v1

; Memory declarations and loads can be asserted directly from the language.
entry test
module loadFloatAssertions
; loadFloat reads the float value stored at an address.
float firstInput 69.1
push &firstInput
loadFloat
push 69.1
call assertf

float secondInput 0.1
push &secondInput
loadFloat
push 0.1
call assertf

float thirdInput -420.1
push &thirdInput
loadFloat
push -420.1
call assertf
moduleEnd

module anonymousFloatDeclarationsCompile
; Anonymous float declarations can be read back through indexed module references.
float
push &this:0
loadFloat
push 0.0
call assertf

float 3.14
push &this:1
loadFloat
push 3.14
call assertf

const PI 3.14159
float PI
push &this:2
loadFloat
push 3.14159
call assertf

float -2.5
push &this:3
loadFloat
push -2.5
call assertf
moduleEnd

module intDeclarationAssertions
; Integer declarations cover named, anonymous, string, and constant-backed defaults.
int
push &this:0
load
push 0
call assert

int 42
push &this:1
load
push 42
call assert

int foo 42
push foo
push 42
call assert

int charValue "e"
push charValue
push 101
call assert

int "e"
push &this:4
load
push 101
call assert

const MY_VALUE 100
int MY_VALUE
push &this:5
load
push 100
call assert

int -42
push &this:6
load
push -42
call assert
moduleEnd

module intSplitByteDeclarationAssertions
; Split-byte defaults are packed into 32-bit integer values.
int splitHex 0xA8 0xFF
push splitHex
push -1459683328
call assert

int splitHexFull 0xA8 0xFF 0x00 0x00
push splitHexFull
push -1459683328
call assert

int 0xA8 0xFF
push &this:2
load
push -1459683328
call assert

int splitDecimal 32 64
push splitDecimal
push 541065216
call assert

int splitString "AB"
push splitString
push 1094844416
call assert

int splitDecimalFull 32 64 0 0
push splitDecimalFull
push 541065216
call assert

int 32 64
push &this:6
load
push 541065216
call assert

int 32
push &this:7
load
push 32
call assert

int mixedBytes 0xA8 255
push mixedBytes
push -1459683328
call assert
moduleEnd

module intConstantSplitByteDeclarationAssertions
; Constants can participate in split-byte defaults for named and anonymous memory.
const HI 32
const LO 64
int foo HI LO
push foo
push 541065216
call assert

int HI LO
push &this:1
load
push 541065216
call assert

int mixed 0xA8 LO
push mixed
push -1472200704
call assert

int 0xA8 LO
push &this:3
load
push -1472200704
call assert
moduleEnd

module intPointerDeclarationsCompile
; Anonymous pointer declarations default to address zero.
int*
push &this:0
load
push 0
call assert
moduleEnd
