8f4e/v1

; The main entry should compile,
; but the fixture runner only
; executes the test entry.
entry main
module productionEntryDoesNotRun
push 1
push 2
add
call assert 4
moduleEnd
entryEnd

; Test entry modules are
; executed by the compiler
; fixture
; runner.
entry test
module testEntryRunsAssertions
push 1
push 2
add
call assert 3
moduleEnd

; Test modules can declare
; memory and pass addresses into
; imported or user-defined
; functions.
module testEntrySupportsPointerArguments
int[] values 2 7 8
push &values
call readFirst
call assert 7
moduleEnd
entryEnd

; Helper used by the
; pointer-address test module.
function readFirst
#impure
param int* pointer
push *pointer
functionEnd int
