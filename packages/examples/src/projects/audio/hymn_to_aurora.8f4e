function maskEffect
; @pos 335 -128
use mod
param int row

push row
push EFFECT_NIBBLE
and
push EFFECT_NIBBLE_SHIFT
shiftRight

functionEnd int

function maskParam
; @pos 335 -110
use mod
param int row

push row
push EFFECT_PARAM
and
push EFFECT_PARAM_SHIFT
shiftRight

functionEnd int

function maskPeriod
; @pos 298 -110
use mod
param int row

push row
push PERIOD_HI
and
push PERIOD_SHIFT
shiftLeft
push row
push PERIOD_LO
and
push PERIOD_SHIFT
shiftRight
or

functionEnd int

function maskSampleNumber
; @pos 297 -128
use mod
param int row

push row
push SAMPLE_HI_NIBBLE
and
push row
push SAMPLE_LO_NIBBLE
and
push SAMPLE_LO_NIBBLE_SHIFT
shiftRight
or

functionEnd int

function period2Step
; @pos 261 -128
param int period
use mod
use env

push period
equalToZero
if
push 0.0
return
ifEnd

push PAL_AMIGA_CLOCK/2
push period
castToFloat
ensureNonZero
div
push SAMPLE_RATE
castToFloat
div

functionEnd float

