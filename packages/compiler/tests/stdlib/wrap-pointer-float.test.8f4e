entry test
module wrapPointerFloatAssertions
; it wraps float pointer
; addresses before and after a
; circular buffer.
float[] buffer 4 1.25
int pointer &buffer
const BYTE_LENGTH count(buffer)*sizeof(buffer)

push pointer
push sizeof(buffer)*2
add
push &buffer
push BYTE_LENGTH
call wrapPointer
push &buffer+8
call assert

push pointer
push BYTE_LENGTH
add
push &buffer
push BYTE_LENGTH
call wrapPointer
push &buffer
call assert

push pointer
push sizeof(buffer)
sub
push &buffer
push BYTE_LENGTH
call wrapPointer
push buffer&
call assert
moduleEnd
entryEnd
