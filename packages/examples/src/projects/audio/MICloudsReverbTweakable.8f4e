float* buffer 
- &allpassDiffuser:buffer
float** pointer 
- &allpassDiffuser:pointer
float* in &modulatedDelayTap:out
int* writeOffset
- &controlValues:smearWriteOffset

const SIZE sizeof(*buffer)

push *pointer
push *writeOffset
castToFloat
push CLOUDS_RATIO
mul
castToInt
push SIZE
mul
add
push buffer
push count(*buffer)
call wrapPointer
push *in
store

moduleEnd
module allpassDiffuser
