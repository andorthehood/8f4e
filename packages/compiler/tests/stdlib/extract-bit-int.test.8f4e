includes
include std/bitwise/extractBit
includesEnd

entry test
module extractBitIntAssertions
; it extracts individual bits
; from an integer word starting
; at the least-significant bit.
push 0b10100100
push 0
call extractBit
call assert 0

push 0b10100100
push 2
call extractBit
call assert 1

push 0b10100100
push 5
call extractBit
call assert 1

push 0b10100100
push 6
call extractBit
call assert 0

push -1
push 31
call extractBit
call assert 1
moduleEnd
entryEnd
