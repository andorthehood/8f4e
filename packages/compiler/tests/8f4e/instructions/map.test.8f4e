8f4e/v1

; map runtime behavior is asserted through source-level fixtures.
entry test
module mapIntIntAssertions
; Integer maps return matching values and fall back to implicit zero.
int input

push &input
push 1
store
push input
mapBegin int
map 1 100
map 2 200
map 3 300
mapEnd int
push 100
call assert

push &input
push 2
store
push input
mapBegin int
map 1 100
map 2 200
map 3 300
mapEnd int
push 200
call assert

push &input
push 3
store
push input
mapBegin int
map 1 100
map 2 200
map 3 300
mapEnd int
push 300
call assert

push &input
push 99
store
push input
mapBegin int
map 1 100
map 2 200
map 3 300
mapEnd int
push 0
call assert
moduleEnd

module mapCharLiteralAssertions
; Single-character literals map through their ASCII integer values.
int input

push &input
push 65
store
push input
mapBegin int
map "A" "B"
mapEnd int
push 66
call assert

push &input
push 66
store
push input
mapBegin int
map "A" "B"
mapEnd int
push 0
call assert
moduleEnd

module mapDefaultAssertions
; Explicit defaults are returned when no row matches.
int input

push &input
push 1
store
push input
mapBegin int
map 1 10
default 999
mapEnd int
push 10
call assert

push &input
push 0
store
push input
mapBegin int
map 1 10
default 999
mapEnd int
push 999
call assert

push &input
push 42
store
push input
mapBegin int
map 1 10
default 999
mapEnd int
push 999
call assert
moduleEnd

module mapIntFloatAssertions
; Integer keys can map to float outputs.
int input

push &input
push 0
store
push input
mapBegin int
map 0 0.5
map 1 1.5
mapEnd float
push 0.5
call assertf

push &input
push 1
store
push input
mapBegin int
map 0 0.5
map 1 1.5
mapEnd float
push 1.5
call assertf

push &input
push 2
store
push input
mapBegin int
map 0 0.5
map 1 1.5
mapEnd float
push 0.0
call assertf
moduleEnd

module mapFloatFloatAssertions
; Float keys can map to float outputs.
