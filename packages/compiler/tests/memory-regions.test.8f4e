; @memoryRegions sampleMemory displayMemory

; Logical memory regions should behave correctly when executed through exported entries.
entry test
module regionSamples
; #region declarations allocate their memory in the configured region.
#region sampleMemory
int8[] values 4 11
moduleEnd

module rawAddressRegionSource
; Raw addresses should still target default memory even when another region has data at the same address.
#region sampleMemory
int source 99
moduleEnd

module rawAddressDefaultReader
; The raw address 4 reads the default memory source, not the sampleMemory source.
int source 42
int result

push &result
push 4
load
store

push result
push 42
call assert
moduleEnd

module regionPointerReader
; Pointer provenance should dereference through the source region and store into default memory.
int result
int8* ptr &regionSamples:values

push &result
push *ptr
store

push result
push 11
call assert
moduleEnd

module regionCopySource
; memoryCopy should infer its source memory from address provenance.
#region sampleMemory
int8[] values 4 1 2 3 4
moduleEnd

module crossRegionCopyAssertions
; Cross-region memoryCopy should copy bytes from sampleMemory into default memory.
int8[] copy 4

push &copy
push &regionCopySource:values
memoryCopy 4

push &copy
load8u
push 1
call assert

push &copy
push 1
push sizeof(copy)
mul
add
load8u
push 2
call assert

push &copy
push 2
push sizeof(copy)
mul
add
load8u
push 3
call assert

push &copy
push 3
push sizeof(copy)
mul
add
load8u
push 4
call assert
moduleEnd

module numericDefaultRegion
; #region 0 keeps declarations in default memory.
#region 0
int value 7

push value
push 7
call assert
moduleEnd

module numericCustomRegion
; Numeric region indices should target the configured custom region.
#region 2
int pixel 9

push pixel
push 9
call assert
moduleEnd

module regionInternalResource
; Compiler-generated internal resources should stay in default memory even when the module declares a custom region.
#region sampleMemory
int input
int output

push &output
push input
hasChanged
if
push 1
else
push 0
ifEnd int
store

push output
push 0
call assert
moduleEnd
entryEnd
