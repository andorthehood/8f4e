includes
include std/math/trig/sine
includesEnd

entry test
module sineAssertions
; it approximates sine at
; cardinal phase points.
push 0.0
call sine
call assert 0.0

push 1.570796326794896
call sine
call assert 1.0

push 3.141592653589793
call sine
call assert 0.0

push -1.570796326794896
call sine
call assert -1.0
moduleEnd
entryEnd
