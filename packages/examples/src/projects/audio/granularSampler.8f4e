module pcmPlayer
; @pos -39 -27
; @home
use env

int16[] buffer ASSET_PIANO_SIZE/2
; @config bin.piano.memory buffer
float* speed &controlValues:speed
float* position &position:out
int16* playhead &buffer ; @w
float out

;                                                                         
; @wave2 &buffer count(buffer) playhead

local float samplePosition
local int sampleAddress

; Calculate read address
push *position
push count(buffer)
castToFloat
mul
localSet samplePosition

push samplePosition
castToInt
push sizeof(buffer)
mul
push &buffer
add
localSet sampleAddress

push &playhead
push sampleAddress
store

; Interpolate sample at
; fractional playhead position
; write it to output
push &out
push sampleAddress
push &buffer
push count(buffer)
push samplePosition
call fract
call readInterpolated
push max(buffer)
castToFloat
div
push 8.0
div
store

moduleEnd
