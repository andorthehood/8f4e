mul
push *smoothedIn
push *volSmoothed
mul
add
store

moduleEnd

module notes
; @pos 11 -85
; Plays a 8-bit PCM audio sample with a
; variable-speed floating-point playhead,
; applies a minBLEP (minimum-band-limited
; step) correction with a 16-sample ring
; buffer to smooth sample discontinuities,
; then low-pass filters the result before
; routing it to audioout.
moduleEnd

module params
; @pos 66 -93
float increment 0.2 ; @w
float volOriginal 0.0 ; @w
float volSmoothed 1.0; @w
; @home top
; You can change the playback speed 
; by dragging this slider below.

; @slider &increment

; @crossfade &volOriginal &volSmoothed

moduleEnd

module pcmPlayer
; @pos 122 -73
use env

int8[] buffer ASSET_AMEN_SIZE
; @loadAsset amen &buffer
int8* playhead &buffer
float position 0.0 ; @w
float readPosition 0.0 ; @w
float* increment &params:increment
float out

; @wave &buffer count(buffer) playhead

; Capture the current read position
; before advancing the playhead.
push &readPosition
push position
store

; Calculate read address from float position
push &playhead
push readPosition
castToInt
push &buffer
add
store

; Read sample at playhead
; write it to output
push &out
push *playhead
castToFloat
push max(buffer)
castToFloat
div
store

; Advance the float position
push &position
push position
push *increment
add
store

; Reset position
; when it reaches buffer end
push position
castToInt
push count(buffer)
greaterOrEqual
if
push &position
push 0.0
store
ifEnd

moduleEnd

