8f4e/v1

; Stack instructions should leave modules with an empty stack after assertions.
entry test
module dropAssertions
; drop removes the top value so later assertions can run on a clean stack.
push 1
drop

push 2
push 2
add
push 4
call assert
moduleEnd

module clearStackAssertions
; clearStack removes all values currently on the stack.
push 1
push 1
clearStack

push 3
push 4
add
push 7
call assert
moduleEnd

module blockIntAssertions
; blockEnd can return integer values from a nested stack region.
block
 push 69
blockEnd int
push 69
call assert

block
 push 1
blockEnd int
push 1
call assert

block
 push -420
blockEnd int
push -420
call assert
moduleEnd

module blockFloatAssertions
; blockEnd can return float values from a nested stack region.
block
 push 69.1
blockEnd float
push 69.1
call assertf

block
 push 1.1
blockEnd float
push 1.1
call assertf

block
 push -420.1
blockEnd float
push -420.1
call assertf
moduleEnd
entryEnd
