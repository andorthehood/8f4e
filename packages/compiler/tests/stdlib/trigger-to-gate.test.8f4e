includes
include std/events/triggerToGate
includesEnd

entry test
module triggerToGateIntAssertions
; it holds an int trigger open
; for the requested duration.
int remainingSamples

push 0
push 3
call triggerToGate &remainingSamples
call assert 0
push remainingSamples
call assert 0

push 1
push 3
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 2

push 0
push 3
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 1

push 0
push 3
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 0

push 0
push 3
call triggerToGate &remainingSamples
call assert 0

push 1
push 2
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 1

push 1
push 4
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 3
moduleEnd

module triggerToGateFloatAssertions
; it treats positive float
; values as triggers.
int remainingSamples

push 0.0
push 2
call triggerToGate &remainingSamples
call assert 0

push 0.5
push 2
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 1

push -0.5
push 2
call triggerToGate &remainingSamples
call assert 1
push remainingSamples
call assert 0

push 0.0
push 2
call triggerToGate &remainingSamples
call assert 0
moduleEnd
entryEnd
