module amigaTick
; @pos 28 -9
use mod

int tempo 125
int out
int counter

; @watch counter

push &out
push 0
store

push counter
push ROW_SAMPLES
push tempo
ensureNonZero
div
greaterThan
if
push &counter
push 0
store
push &out
push 1
store
ifEnd

push &counter
push counter
push 1
add
store

moduleEnd

