{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^default"
      ],
      "cache": true
    },
    "dev": {
      "cache": false
    },
    "test": {
      "inputs": [
        "default",
        "^default"
      ],
      "cache": true
    },
    "typecheck": {
      "inputs": [
        "default",
        "^default"
      ],
      "cache": true
    },
    "lint": {
      "inputs": [
        "default",
        "^default"
      ],
      "cache": true
    }
  },
  "generators": {
    "@nx/js:library": {
      "unitTestRunner": "vitest"
    }
  },
  "release": {
    "projects": ["*", "!glugglug"],
    "projectsRelationship": "independent",
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    },
    "version": {
      "specifierSource": "conventional-commits",
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk",
      "updateDependents": "never",
      "manifestRootsToUpdate": ["{projectRoot}"]
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": false
    },
    "git": {
      "commit": true,
      "commitMessage": "chore(release): version packages",
      "tag": true,
      "push": false
    }
  },
  "nxCloudAccessToken": null,
  "defaultBase": "HEAD~1",
  "analytics": false
}
