module volume1
; @pos 390 -72
; @group ch1
use mod
int* row &rowBuffer1:
int* tick &modTickClock:out
int* rowTrigger &modRowClock:out
int* rowCounter &rowCount2:out
int out ; @w
; @hide
; Reload base volume on
; tick 0 / row advance.
push *rowCounter
hasChanged
if
push *row
call rowShouldReloadVolume
if
push &out
push *row
call loadRowVolume
store
ifEnd
ifEnd

; Apply volume slide only on
; later ticks in the row.
push *rowTrigger
equalToZero
if
push *tick
risingEdge
if
push &out
push out
push *row
call rowVolumeSlideDelta
add
call clampVolume
store
ifEnd
ifEnd

moduleEnd

