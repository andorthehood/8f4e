8f4e/v1

; Float instruction behavior is
; checked through the shared
; imported assert helper.
entry test
module floatMulAssertions
; Float multiplication is
; approximate because
; WebAssembly stores
; these values as floats.
push 4.001
push 0.5
mul
call assert 2.0
moduleEnd

module floatDivAssertions
; Float division uses assert
; for tolerance-based
; comparison.
push 420.001
push 69.001
ensureNonZero
div
call assert 6.0869
moduleEnd

module floatAbsAssertions
; abs returns positive float
; magnitudes.
push 1.1
abs
call assert 1.1

push -1.1
abs
call assert 1.1

push -69.1
abs
call assert 69.1

push 420.1
abs
call assert 420.1
moduleEnd

module castToFloatAssertions
; castToFloat should preserve
; integer magnitude when
; converting
; to float.
push 1
castToFloat
call assert 1.0

push -69
castToFloat
call assert -69.0

push 0
castToFloat
call assert 0.0

push 420
castToFloat
call assert 420.0
moduleEnd

module castToIntAssertions
; castToInt truncates toward
; zero.
push 1.1
castToInt
call assert 1

push -69.69
castToInt
call assert -69

push 0.001
castToInt
call assert 0

push 420.99
castToInt
call assert 420
moduleEnd

module roundAssertions
; round follows the compiler's
; current half-down behavior.
push 4.1
round
call assert 4.0

push 4.5
round
call assert 4.0

push 4.51
round
call assert 5.0

push 4.6
round
call assert 5.0

push 4.9
round
call assert 5.0
moduleEnd

module sqrtAssertions
; sqrt returns approximate float
; square roots.
push 4.001
sqrt
call assert 2.0

push 16.001
sqrt
call assert 4.0
moduleEnd
entryEnd
