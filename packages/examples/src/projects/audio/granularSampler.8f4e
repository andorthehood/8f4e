module modulatedDelayTap
; @pos 127 -27
; @group smearStage1
; Reads a modulated, 
; interpolated tap 
; from a delay buffer
use cloudsReverb

float* buffer 
- &allpassDiffuser:buffer
float** pointer 
- &allpassDiffuser:pointer
float* mod &lfo1:out
float out

const SIZE sizeof(*buffer)
const MOD_BASE_OFFSET 
- 10.0*CLOUDS_RATIO
const MOD_DEPTH 
- 60.0*CLOUDS_RATIO

push &out
; pointer + 
; int((10 + mod * 60) * ratio) * SIZE
push *pointer
push MOD_BASE_OFFSET
push *mod
push MOD_DEPTH
mul
add
castToInt
push SIZE
mul
add

; Circular buffer range
push buffer
push count(*buffer)

; fraction((10 + mod * 60) * ratio)
push MOD_BASE_OFFSET
push *mod
push MOD_DEPTH
mul
add
call fract

call readInterpolated
store

moduleEnd
