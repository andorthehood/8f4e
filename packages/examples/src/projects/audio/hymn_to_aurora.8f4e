module modRowCounter
; @pos 103 -9
use env
int* trigger &amigaTick:out 
int rowCounter 
int* patternPointer &patternOrder:
int out ; @w

; @watch rowCounter
; @watch out
; @watch patternCounter

push &out
push rowCounter
push *patternPointer
push 64
mul
add
store

; Advance the playhead
push *trigger
risingEdge
if
push &rowCounter
push rowCounter
push 1
add
store
ifEnd

push rowCounter
push 64
equal
if
push &rowCounter
push 0
store

push &patternPointer
push patternPointer
push sizeof(*patternPointer)
add
store
ifEnd

push patternPointer
push patternOrder:&
greaterThan
if
push &patternPointer
push &patternOrder:
store
ifEnd

moduleEnd

module modSamplePlayer1
; @pos 398 -69
; @group ch0
use env

float out; @w
int* period &period1:out
float _position 0.0; @w
int* trigger &trigger1:out
int _playing; @w
int* sampleNumber &sampleNumber1:out
int8* sampleAddress; @w
int sampleSize; @w
int8* playhead; @w

; @wave sampleAddress sampleSize playhead

; @hide

push &sampleAddress
push *sampleNumber
call sampleNumberToAddr
store

push &sampleSize
push *sampleNumber
call sampleNumberToSize
store

push *trigger
risingEdge
if
push &_playing
push 1
store
push &_position
push 0
store
ifEnd

; Calculate read address
push &playhead
push _position
castToInt
push sampleAddress
add
store

; Read sample at playhead
; write it to output
push &out
push *playhead
castToFloat
push max(*sampleAddress) ; max value
castToFloat
div
store

; Advance the playhead
push _playing
if
push &_position
push _position
push *period
call period2Step
add
store
ifEnd

; Stop playing
; when reaches buffer end
push _position
castToInt
push *sampleNumber
call sampleNumberToSize
greaterThan
if
push &_playing
push 0
store
ifEnd

moduleEnd

