{
  "name": "@8f4e/compiler-spec",
  "sourceRoot": "packages/compiler/packages/compiler-spec/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "rm -rf dist && tsc --emitDeclarationOnly && vite build",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["^build"]
    }
  },
  "tags": ["type:library", "scope:core"]
}
