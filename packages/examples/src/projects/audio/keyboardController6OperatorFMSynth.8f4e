module audioout
; @pos 675 39
; ~audioOutput buffer 0 0
; ~audioOutput buffer 0 1
use env

float* in &limiter:out

; Audio buffer
float[] buffer AUDIO_BUFFER_SIZE
int pointer &buffer

; @plot &buffer count(buffer)

; Store the input value
; in the buffer
push pointer
push *in
store

; Increment the buffer 
; pointer by the
; buffer word size
push &pointer
push pointer
push sizeof(buffer)
add
store

; Reset the buffer pointer
; when it reaches the end
; of the buffer
push pointer
push buffer&
greaterThan
if
push &pointer
push &buffer
store
ifEnd

moduleEnd

module bpmClock
; @pos 414 -92
use env

int bpm 12
int out
int counter 

; @watch counter

push &out
push 0
store

push counter
push SAMPLE_RATE
push 60
mul
push bpm
ensureNonZero
div
greaterThan
if
push &counter
push 0
store
push &out
push 1
store
ifEnd

push &counter
push counter
push 1
add
store

moduleEnd

