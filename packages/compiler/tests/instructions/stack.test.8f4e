8f4e/v1

; Stack instructions should
; leave modules with an empty
; stack
; after assertions.
entry test
module dropAssertions
; drop removes the top value so
; later assertions can run on a
; clean stack.
push 1
drop

push 2
push 2
add
call assert 4
moduleEnd

module clearStackAssertions
; clearStack removes all values
; currently on the stack.
push 1
push 1
clearStack

push 3
push 4
add
call assert 7
moduleEnd

module blockIntAssertions
; blockEnd can return integer
; values from a nested stack
; region.
block
 push 69
blockEnd int
call assert 69

block
 push 1
blockEnd int
call assert 1

block
 push -420
blockEnd int
call assert -420
moduleEnd

module blockFloatAssertions
; blockEnd can return float
; values from a nested stack
; region.
block
 push 69.1
blockEnd float
call assert 69.1

block
 push 1.1
blockEnd float
call assert 1.1

block
 push -420.1
blockEnd float
call assert -420.1
moduleEnd
entryEnd
