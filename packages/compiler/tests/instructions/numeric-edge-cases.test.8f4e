8f4e/v1

; Numeric edge cases are executable fixtures so the real Wasm runtime path is covered.
entry test
module castToIntSaturatesOutOfRangeFloat32
; castToInt should saturate positive out-of-range float32 values.
push 2147483648.0
castToInt
push 2147483647
call assert
moduleEnd

module castToIntConvertsNaNToZero
; castToInt should convert NaN float32 values to zero.
push -1.0
sqrt
castToInt
push 0
call assert
moduleEnd

module minMaxIntAssertions
; min and max should select the smaller and larger signed integer operands.
push 10
push -3
min
push -3
call assert

push 10
push -3
max
push 10
call assert
moduleEnd

module minMaxFloatAssertions
; min and max should select the smaller and larger float32 operands.
push 0.5
push 0.7
min
push 0.5
call assertf

push 0.5
push 0.7
max
push 0.7
call assertf
moduleEnd

module minMaxFloat64Assertions
; min and max should select the smaller and larger float64 operands.
push 1.25f64
push 1.125f64
min
push 1.125f64
call assertf64

push 1.25f64
push 1.125f64
max
push 1.25f64
call assertf64
moduleEnd

module remainderWithNonZeroConstant
; Remainder should run when the divisor is a known non-zero constant.
push 5
push 2
remainder
push 1
call assert
moduleEnd
entryEnd
