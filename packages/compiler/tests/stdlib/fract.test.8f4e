includes
include std/math/fract
includesEnd

entry test
module fractAssertions
; it returns the fractional part
; of positive float values.
push 0.0
call fract
call assert 0.0

push 3.25
call fract
call assert 0.25

push 10.75
call fract
call assert 0.75

push 60.999
call fract
call assert 0.999
moduleEnd
entryEnd
