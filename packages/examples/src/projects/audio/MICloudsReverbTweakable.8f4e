module lfo1
; @pos 90 -27
; @group smearStage1
use env

float* frequency &controlValues:smearLfoFrequency
float phase
float out

push &out
push &phase
push *frequency
push SAMPLE_RATE
call advancePhase
; You can swap this call
; with any periodic function
call cosine

push 1.0
add
push 2.0
div

store

moduleEnd
module modulatedDelayTap
; @pos 127 -27
; @group smearStage1
; Reads a modulated, 
; interpolated tap 
; from a delay buffer
use cloudsReverb

float* buffer 
- &allpassDiffuser:buffer
float** pointer 
- &allpassDiffuser:pointer
float* mod &lfo1:out
int* baseOffset
- &controlValues:smearTapBase
int* depth
- &controlValues:smearTapDepth
float out

const SIZE sizeof(*buffer)

push &out
; pointer + 
; int((10 + mod * 60) * ratio) * SIZE
push *pointer
push *baseOffset
castToFloat
push CLOUDS_RATIO
mul
push *mod
push *depth
castToFloat
push CLOUDS_RATIO
mul
mul
add
castToInt
push SIZE
mul
add

; Circular buffer range
push buffer
push count(*buffer)

; fraction((10 + mod * 60) * ratio)
push *baseOffset
castToFloat
push CLOUDS_RATIO
mul
push *mod
push *depth
castToFloat
push CLOUDS_RATIO
mul
mul
add
call fract

call readInterpolated
store

moduleEnd
module delayOffsetWriter
; @pos 173 -27
; @group smearStage1
