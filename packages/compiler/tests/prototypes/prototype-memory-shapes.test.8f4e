8f4e/v1

; describes a reusable module
; memory shape with defaults
prototype oscillatorState
float phase
float frequency 440
prototypeEnd

entry test
module oscA
shape oscillatorState
int localA 11

; it expands prototype fields
; before local declarations
push phase
call assert 0.0

; it preserves default values
; from prototype fields
push frequency
call assert 440.0

; it preserves declarations
; written in the consuming
; module
push localA
call assert 11

; it lays out expanded prototype
; fields in declaration order
push &phase
push &frequency
lessThan
call assert 1

; it lays out local declarations
; after a leading shape
; instruction
push &frequency
push &localA
lessThan
call assert 1
moduleEnd

module oscB
int localB 22
shape oscillatorState

; it preserves declarations that
; appear before a shape
; instruction
push localB
call assert 22

; it expands prototype fields
; after earlier local
; declarations
push phase
call assert 0.0

; it reuses prototype defaults
; in each consuming module
push frequency
call assert 440.0

; it lays out shape fields after
; preceding local declarations
push &localB
push &phase
lessThan
call assert 1

; it allocates separate storage
; for each module that uses the
; shape
push &phase
push &oscA:phase
notEqual
call assert 1
moduleEnd
entryEnd
