{
	"name": "@8f4e/metrics-dashboard",
	"sourceRoot": "packages/metrics-dashboard/src",
	"projectType": "application",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist"],
			"options": {
				"command": "vite build",
				"cwd": "{projectRoot}"
			}
		},
		"serve": {
			"executor": "nx:run-commands",
			"options": {
				"command": "vite --host 0.0.0.0 --port 3001",
				"cwd": "{projectRoot}"
			}
		},
		"preview": {
			"executor": "nx:run-commands",
			"options": {
				"command": "vite preview --host 0.0.0.0 --port 3001",
				"cwd": "{projectRoot}"
			},
			"dependsOn": ["build"]
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --noEmit",
				"cwd": "{projectRoot}"
			}
		}
	},
	"tags": ["type:application", "scope:tooling"]
}
