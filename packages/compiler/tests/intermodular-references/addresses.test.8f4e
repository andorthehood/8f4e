8f4e/v1

; Intermodule address references
; should resolve to usable
; memory
; addresses.
entry test
module addressSource
; The source module gives start,
; end, scalar-end, and
; module-end
; references visible values.
int[] buffer 3 11 22 33
int scalar 42
int tail 99
moduleEnd

module addressReferenceAssertions
; Start-address references
; should point at the first
; value.
int* bufferStart &addressSource:buffer
int* moduleStart &addressSource:

push *bufferStart
call assert 11

push *moduleStart
call assert 11

; End-address references should
; point at the final
; word-aligned
; element.
int* bufferEnd addressSource:buffer&
int* scalarEnd addressSource:scalar&
int* moduleEnd addressSource:&

push *bufferEnd
call assert 33

push *scalarEnd
call assert 42

push *moduleEnd
call assert 99
moduleEnd

module outOfOrderAddressAssertions
; Named start and end references
; can resolve to modules
; declared
; later in the entry.
int* start &lateAddressSource:buffer
int* end lateAddressSource:buffer&

push *start
call assert 5

push *end
call assert 8
moduleEnd

module lateAddressSource
int[] buffer 4 5 6 7 8
moduleEnd

module nthAddressSource
; Nth references address memory
; declarations by declaration
; slot, not by array element.
int a 10
int b 20
int c 30
moduleEnd

module nthAddressAssertions
; &module:0 is the first memory
; item and matches the module
; base
; address.
int* first &nthAddressSource:0
int* base &nthAddressSource:
int* second &nthAddressSource:1
int* third &nthAddressSource:2

push first
push base
equal
call assert 1

push *first
call assert 10

push *second
call assert 20

push *third
call assert 30
moduleEnd

module nthArraySource
; Arrays count as one
; declaration slot for nth
; references.
int[] buffer 10 0
int scalar 60
moduleEnd

module nthArrayAssertions
int* scalar &nthArraySource:1

push *scalar
call assert 60
moduleEnd

module sameModuleAddressAssertions
; Same-module start and end
; references should resolve in
; declaration initializers.
int[] buffer 5 1 2 3 4 5
int* startPtr &buffer
int* endPtr buffer&

push *startPtr
call assert 1

push *endPtr
call assert 5
moduleEnd

module currentModuleShorthandAssertions
; Current-module shorthand
; references should resolve
; start, end,
; and nth declaration addresses.
int a 10
int b 20
int[] tail 2 30 40
int* moduleStart &this
int* moduleEndPtr this&
int* second &this:1

push *moduleStart
call assert 10

push *second
call assert 20

push moduleEndPtr
push &moduleEndPtr
push sizeof(moduleEndPtr)
add
equal
call assert 1
moduleEnd
entryEnd
