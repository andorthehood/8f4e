function modFinetune
; @pos 472 -128
const STEP 96.0

const FT_P0 0/STEP
const FT_P1 1/STEP
const FT_P2 2/STEP
const FT_P3 3/STEP
const FT_P4 4/STEP
const FT_P5 5/STEP
const FT_P6 6/STEP
const FT_P7 7/STEP
const FT_P8 8/STEP

const FT_N0 0/STEP
const FT_N1 -1/STEP
const FT_N2 -2/STEP
const FT_N3 -3/STEP
const FT_N4 -4/STEP
const FT_N5 -5/STEP
const FT_N6 -6/STEP
const FT_N7 -7/STEP
const FT_N8 -8/STEP

param int fineTune
push fineTune
mapBegin int
map -8 2^FT_P8
map -7 2^FT_P7
map -6 2^FT_P6
map -5 2^FT_P5
map -4 2^FT_P4
map -3 2^FT_P3
map -2 2^FT_P2
map -1 2^FT_P1
map  0 2^FT_N0
map  1 2^FT_N1
map  2 2^FT_N2
map  3 2^FT_N3
map  4 2^FT_N4
map  5 2^FT_N5
map  6 2^FT_N6
map  7 2^FT_N7
mapEnd float

functionEnd float

