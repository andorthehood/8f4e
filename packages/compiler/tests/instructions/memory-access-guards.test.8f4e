8f4e/v1

; Guarded memory access should return zero instead of trapping for unsafe addresses.
entry test
module guardedIntLoadAssertions
; Unsafe integer loads should return zero instead of trapping.
push -1
load
call assert 0

push 65533
load
call assert 0

push 2147483647
load
call assert 0
moduleEnd

module guardedFloatLoadAssertions
; Unsafe float loads should return zero instead of trapping.
push -1
loadFloat
call assertf 0.0

push 65533
loadFloat
call assertf 0.0

push 2147483647
loadFloat
call assertf 0.0
moduleEnd

module guardedLocalPointerDereferenceAssertions
; Unsafe pointer dereferences inside impure functions should return zero.
push -1
call readGuardedPointer
call assert 0

push 65533
call readGuardedPointer
call assert 0

push 2147483647
call readGuardedPointer
call assert 0
moduleEnd
entryEnd

function readGuardedPointer
#impure
param int* ptr

push *ptr
functionEnd int
