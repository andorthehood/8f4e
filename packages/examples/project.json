{
	"name": "@8f4e/examples",
	"sourceRoot": "src",
	"projectType": "library",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist"],
			"dependsOn": ["^build"],
			"options": {
				"command": "node ./src/module-generators/generateModules.ts && ./generate-project-wasm.sh && node ./generate-example-registries.mjs",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "eslint src --fix",
				"cwd": "{projectRoot}"
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node ./src/module-generators/generateModules.ts && tsc --watch",
				"cwd": "{projectRoot}"
			}
		},
		"log-opcode-size": {
			"executor": "nx:run-commands",
			"cache": false,
			"outputs": ["{workspaceRoot}/logs/opcode-size"],
			"dependsOn": [
				{
					"projects": ["@8f4e/cli"],
					"target": "build",
					"params": "ignore"
				}
			],
			"options": {
				"command": "node scripts/log-opcode-sizes.mjs",
				"cwd": "{workspaceRoot}"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --project tsconfig.typecheck.json --noEmit",
				"cwd": "{projectRoot}"
			},
			"dependsOn": ["^build"]
		}
	},
	"tags": ["type:library", "scope:examples"]
}
