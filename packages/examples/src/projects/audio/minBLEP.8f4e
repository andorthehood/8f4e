function positionIncrementToBlepPhaseInterpolated
; @pos 223 -138
param float position
param float increment
; Convert the fractional part of
; the current read position into
; a 0..16 BLEP phase based on
; where the discontinuity occurred
; inside the output sample interval.
push 1.0
push position
call frac
push increment
ensureNonZero 0.000001
div
sub
push 16.0
mul

functionEnd float

function positionIncrementToBlepPhaseNonInterpolated
; @pos 223 -116
param float position
param float increment
; Convert the fractional part of
; the current read position into
; a 0..15 BLEP phase based on
; where the discontinuity occurred
; inside the output sample interval.
push position
push increment
call positionIncrementToBlepPhaseInterpolated
castToInt

functionEnd int

function wrapAdd16
; @pos 98 -136
param int base
param int offset
local int sum

; Add an offset and wrap
; the result into a 16-slot ring.
push base
push offset
add
localSet sum

push sum
push 16
greaterOrEqual
if
push sum
push 16
sub
return
ifEnd

push sum

functionEnd int

