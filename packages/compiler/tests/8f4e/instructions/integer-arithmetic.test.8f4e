; Integer arithmetic behavior is checked through the shared imported assert helper.
entry test
module addAssertions
; Addition keeps signed integer behavior across positive, negative, and zero operands.
push 2
push 2
add
push 4
call assert

push -1
push 1
add
push 0
call assert

push -69
push 0
add
push -69
call assert

push 420
push 0
add
push 420
call assert
moduleEnd

; Subtraction keeps signed integer behavior across positive, negative, and zero operands.
