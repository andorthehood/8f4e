function xorshift
#export
#impure
; Advances a signed 32-bit
; XORShift seed and returns the
; next integer value.
param int* seed

push seed
push *seed
push *seed
push 13
shiftLeft
xor
store

push seed
push *seed
push *seed
push 17
shiftRightUnsigned
xor
store

push seed
push *seed
push *seed
push 5
shiftLeft
xor
store

push *seed

functionEnd int
