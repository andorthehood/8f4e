module lowpassL
; @pos 638 -12
float* in &mixer:outL
float state 0.0 ; @w
float out ; @w

use math
use env

const MINUS_2_PI -2*PI
const CUTOFF_TERM MINUS_2_PI*4400
const EXPONENT CUTOFF_TERM/SAMPLE_RATE
const DECAY E^EXPONENT
const COEFFICIENT 1-DECAY

push &out
push state
push *in
push state
sub
push COEFFICIENT
mul
add
store

push &state
push out
store

moduleEnd

