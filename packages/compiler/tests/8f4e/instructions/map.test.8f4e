push &input
push 0.5
store
push input
mapBegin float
map 0.5 10.0
map 1.5 20.0
mapEnd float
push 10.0
call assertf

push &input
push 1.5
store
push input
mapBegin float
map 0.5 10.0
map 1.5 20.0
mapEnd float
