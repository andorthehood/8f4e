8f4e/v1

includes
include std/events/gateToTrigger
includesEnd

entry test
module gateToTriggerIntAssertions
; it emits a one-sample trigger
; when an int gate rises.
int previousInt

push 0
call gateToTrigger &previousInt
call assert 0
push previousInt
call assert 0

push 1
call gateToTrigger &previousInt
call assert 1
push previousInt
call assert 1

push 1
call gateToTrigger &previousInt
call assert 0

push 0
call gateToTrigger &previousInt
call assert 0

push 1
call gateToTrigger &previousInt
call assert 1
moduleEnd

module gateToTriggerFloatAssertions
; it emits a one-sample trigger
; when a float gate rises.
float previousFloat

push 0.0
call gateToTrigger &previousFloat
call assert 0
push previousFloat
call assertf 0.0

push 0.25
call gateToTrigger &previousFloat
call assert 1
push previousFloat
call assertf 0.25

push 0.25
call gateToTrigger &previousFloat
call assert 0

push -0.5
call gateToTrigger &previousFloat
call assert 0

push 0.0
call gateToTrigger &previousFloat
call assert 1
moduleEnd
entryEnd
