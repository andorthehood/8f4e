module volume1
; @pos 302 -71
; @group ch0
use mod
int* row &rowBuffer1:
int* sampleNumber &sampleNumber1:out
int out

; @watch out

; Load default volume
push *sampleNumber
push 0
greaterThan
if
push &out
push *sampleNumber
call sampleNumberToVolume
store
ifEnd

; Load volume from effect
push *row
call maskEffect
push SET_VOLUME
equal
if
push &out
push *row
call maskParam
store
ifEnd

moduleEnd

