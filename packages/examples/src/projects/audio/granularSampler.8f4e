module bpmClock
; @pos -186 -27
use env

int bpm 120
int out
int counter 

; @watch counter

push &out
push 0
store

push counter
push SAMPLE_RATE
push 60
mul
push bpm
ensureNonZero
div
greaterThan
if
push &counter
push 0
store
push &out
push 1
store
ifEnd

push &counter
push counter
push 1
add
store

moduleEnd
module lcg
; @pos -179 15
; Linear congruential 
; generator

const MULTIPLIER 1664525
const INCREMENT 1013904223 
const MODULUS 65536 ; 2^16
int seed 69420

float out ; @w

push &seed
push MULTIPLIER
push seed
mul
push INCREMENT
add
push MODULUS
remainder
store

push &out
push seed
castToFloat
push MODULUS
castToFloat
div 
store

moduleEnd
module posLFO
; @pos -150 -27
use env

float* frequency &controlValues:speed
float phase
float out
int* reset &bpmClock:out
int previousReset

use math

push 0 ; *reset
call risingEdge &previousReset
if
push &phase
push NEG_PI
store
ifEnd

push &out
push &phase
push *frequency
push SAMPLE_RATE
call advancePhase
; You can swap this call
; with any periodic function
call triangle
store

moduleEnd
