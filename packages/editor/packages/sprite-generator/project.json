{
  "name": "@8f4e/sprite-generator",
  "sourceRoot": "src",
  "projectType": "library",
  "targets": {
    "generate-fonts": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/src/fonts/ibmvga8x16/generated",
        "{projectRoot}/src/fonts/spleen5x8/generated",
        "{projectRoot}/src/fonts/spleen6x12/generated",
        "{projectRoot}/src/fonts/terminus8x16/generated",
        "{projectRoot}/src/fonts/spleen8x16/generated",
        "{projectRoot}/src/fonts/terminus8x16bold/generated",
        "{projectRoot}/src/fonts/6x10/generated",
        "{projectRoot}/src/fonts/terminus10x18/generated",
        "{projectRoot}/src/fonts/terminus10x18bold/generated",
        "{projectRoot}/src/fonts/kana12x13/generated",
        "{projectRoot}/src/fonts/spleen12x24/generated",
        "{projectRoot}/src/fonts/terminus12x24/generated",
        "{projectRoot}/src/fonts/terminus12x24bold/generated",
        "{projectRoot}/src/fonts/spleen16x32/generated"
      ],
      "options": {
        "command": "node --experimental-transform-types tools/generate-font-bitmaps.mjs",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build", "generate-fonts"],
      "options": {
        "command": "tsc",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "generate-fonts"],
      "options": {
        "command": "tsc --watch",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "dependsOn": ["generate-fonts"],
      "options": {
        "config": "{projectRoot}/vitest.config.ts",
        "reportsDirectory": "{workspaceRoot}/coverage/{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "generate-fonts"],
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "test:screenshot": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test",
        "cwd": "{projectRoot}"
      }
    },
    "test:screenshot:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --ui",
        "cwd": "{projectRoot}"
      }
    },
    "test:screenshot:update": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --update-snapshots",
        "cwd": "{projectRoot}"
      }
    },
    "test:screenshot:headed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --headed",
        "cwd": "{projectRoot}"
      }
    },
    "test:screenshot:debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --debug",
        "cwd": "{projectRoot}"
      }
    },
    "dev:test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --config screenshot-tests/vite.config.ts",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:library", "scope:graphics"]
}
