8f4e/v1

; Intermodule address references should resolve to usable memory addresses.
entry test
module addressSource
; The source module gives start, end, scalar-end, and module-end references visible values.
int[] buffer 3 11 22 33
int scalar 42
int tail 99
moduleEnd

module addressReferenceAssertions
; Start-address references should point at the first value.
int* bufferStart &addressSource:buffer
int* moduleStart &addressSource:

push *bufferStart
push 11
call assert

push *moduleStart
push 11
call assert

; End-address references should point at the final word-aligned element.
int* bufferEnd addressSource:buffer&
int* scalarEnd addressSource:scalar&
int* moduleEnd addressSource:&

push *bufferEnd
push 33
call assert

push *scalarEnd
push 42
call assert

push *moduleEnd
push 99
call assert
moduleEnd

module outOfOrderAddressAssertions
; Named start and end references can resolve to modules declared later in the entry.
int* start &lateAddressSource:buffer
int* end lateAddressSource:buffer&

push *start
push 5
call assert

push *end
push 8
call assert
moduleEnd

module lateAddressSource
int[] buffer 4 5 6 7 8
moduleEnd

module nthAddressSource
; Nth references address memory declarations by declaration slot, not by array element.
int a 10
int b 20
int c 30
moduleEnd

module nthAddressAssertions
; &module:0 is the first memory item and matches the module base address.
int* first &nthAddressSource:0
int* base &nthAddressSource:
int* second &nthAddressSource:1
int* third &nthAddressSource:2

push first
push base
equal
push 1
call assert

push *first
push 10
call assert

push *second
push 20
call assert

push *third
push 30
call assert
moduleEnd

module nthArraySource
; Arrays count as one declaration slot for nth references.
int[] buffer 10 0
int scalar 60
moduleEnd

module nthArrayAssertions
int* scalar &nthArraySource:1

push *scalar
push 60
call assert
moduleEnd

module sameModuleAddressAssertions
; Same-module start and end references should resolve in declaration initializers.
int[] buffer 5 1 2 3 4 5
int* startPtr &buffer
int* endPtr buffer&

push *startPtr
push 1
call assert

push *endPtr
push 5
call assert
moduleEnd

module currentModuleShorthandAssertions
; Current-module shorthand references should resolve start, end, and nth declaration addresses.
int a 10
int b 20
int[] tail 2 30 40
int* moduleStart &this
int* moduleEndPtr this&
int* second &this:1

push *moduleStart
push 10
call assert

push *second
push 20
call assert

push moduleEndPtr
push &moduleEndPtr
push sizeof(moduleEndPtr)
add
call assert
moduleEnd
entryEnd
