{
  "name": "@8f4e/cli",
  "version": "0.1.3",
  "private": true,
  "description": "CLI for compiling 8f4e projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cli": "bin/cli.js"
