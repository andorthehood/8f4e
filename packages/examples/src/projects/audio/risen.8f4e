module reverb
; @pos 174 -22

float* in &carrier:out
float out

const FEEDBACK 0.3
const SIZE 10000

float[] buffer SIZE
int bufferPointer &buffer


; Compute reverb output
push &out
push bufferPointer
loadFloat
push FEEDBACK
mul
push *in
add
store

; Store the new sample 
; in the buffer
push bufferPointer
push &out
loadFloat
store

; Advance buffer pointer
push &bufferPointer
push bufferPointer
push sizeof(bufferPointer)
add
store

; Wrap buffer pointer back
; to start when reaches end
push bufferPointer
push buffer&
greaterThan
if
push &bufferPointer
push &buffer
store
ifEnd

moduleEnd

