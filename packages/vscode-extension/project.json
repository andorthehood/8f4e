{
	"name": "@8f4e/vscode-extension",
	"sourceRoot": "src",
	"projectType": "library",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist", "{projectRoot}/media/editor"],
			"dependsOn": ["^build"],
			"options": {
				"command": "vite build --config vite.extension.config.ts && vite build --config vite.webview.config.ts",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "biome check --write packages/vscode-extension/src",
				"cwd": "{workspaceRoot}"
			}
		},
		"package": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist/*.vsix"],
			"dependsOn": ["build"],
			"options": {
				"command": "vsce package --no-dependencies --skip-license --out dist/8f4e-vscode-extension-0.1.0.vsix",
				"cwd": "{projectRoot}"
			}
		},
		"install": {
			"executor": "nx:run-commands",
			"dependsOn": ["package"],
			"options": {
				"command": "node scripts/install-local-vsix.mjs",
				"cwd": "{projectRoot}"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"dependsOn": ["^build"],
			"options": {
				"command": "tsc --noEmit",
				"cwd": "{projectRoot}"
			}
		}
	},
	"tags": ["type:tooling", "scope:editor"]
}
