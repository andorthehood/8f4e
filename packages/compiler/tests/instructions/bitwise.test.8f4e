8f4e/v1

; Bitwise instruction behavior is checked through the shared imported assert helper.
entry test
module andAssertions
; `and` should return only the bits present in both operands.
push 1
push 0
and
push 0
call assert

push 3
push 6
and
push 2
call assert
moduleEnd

; `or` should return the bits present in either operand.
module orAssertions
push 1
push 0
or
push 1
call assert

push 3
push 6
or
push 7
call assert
moduleEnd

; `xor` should return only bits that differ between operands.
module xorAssertions
push 1
push 0
xor
push 1
call assert

push 3
push 6
xor
push 5
call assert
moduleEnd

; shiftLeft moves integer bits left by the requested amount.
module shiftLeftAssertions
push 1
push 1
shiftLeft
push 2
call assert

push 1
push 2
shiftLeft
push 4
call assert

push 3
push 3
shiftLeft
push 24
call assert
moduleEnd

; shiftRight moves integer bits right by the requested amount.
module shiftRightAssertions
push 1
push 1
shiftRight
push 0
call assert

push 8
push 2
shiftRight
push 2
call assert

push 12
push 3
shiftRight
push 1
call assert
moduleEnd
entryEnd
