8f4e/v1

prototype mixerState
int a 2
float b 4.5
prototypeEnd

function sumMixer
#impure
paramShape mixerState
push *a
castToFloat
push *b
add
functionEnd float

function orderedMixer
#impure
param int base
paramShape mixerState
param int tail
push base
push *a
add
push *b
castToInt
add
push tail
add
functionEnd int

entry test
module main
shape mixerState

; it expands prototype memory
; declarations into pointer params
pushShape mixerState
call sumMixer
call assertf 6.5

; it preserves source order when
; explicit params and paramShape
; are mixed
push 10
pushShape mixerState
push 3
call orderedMixer
call assert 19
moduleEnd

module overrides
shape mixerState
int a 8
float b 1.5

; it pushes effective overridden
; memory item addresses
pushShape mixerState
call sumMixer
call assertf 9.5
moduleEnd
entryEnd
